@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyTaskForge" as ReadOnlyTaskForge
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class TaskForge
Class ModelManager
Class UserPrefs

Class UniquePersonList
Class UniqueProjectList
Class UniqueTaskList
Class Person
Class Email
Class Name
Class Phone
Class Project
Class Task
Class PersonProject
Class PersonTask

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

TaskForge .up.|> ReadOnlyTaskForge

ModelManager .up.|> Model
Model .right.> ReadOnlyUserPrefs
Model .left.> ReadOnlyTaskForge
ModelManager -left-> "1" TaskForge
ModelManager -right-> "1" UserPrefs
UserPrefs .up.|> ReadOnlyUserPrefs

TaskForge *--> "1" UniquePersonList
TaskForge *--> "1" UniqueProjectList
Project *--> "1" UniqueTaskList
UniquePersonList --> "~* all" Person
UniqueProjectList *--> "~* contains" Project
UniqueTaskList --> "~* contains" Task
Person *--> Name
Person *--> Phone
Person *--> Email
Person *--> "~* projects" PersonProject
Person *--> "~* tasks" PersonTask
PersonProject ..> Project : lookup
PersonTask ..> Task : lookup

Person -[hidden]up--> I
UniquePersonList -[hidden]right-> I
UniqueProjectList -[hidden]right-> I
UniqueTaskList -[hidden]right-> I

Name -[hidden]right-> Phone
Project -[hidden]right-> Task

ModelManager --> "~* filtered" Person
@enduml
