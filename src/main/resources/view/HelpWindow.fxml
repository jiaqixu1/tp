<?xml version="1.0" encoding="UTF-8"?>

  <?import java.net.URL?>
  <?import javafx.geometry.Insets?>
  <?import javafx.scene.Scene?>
  <?import javafx.scene.control.Button?>
  <?import javafx.scene.control.TextArea?>
  <?import javafx.scene.image.Image?>
  <?import javafx.scene.layout.VBox?>
  <?import javafx.stage.Stage?>

  <fx:root resizable="true" title="TaskForge Help" type="javafx.stage.Stage"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <icons>
      <Image url="@/images/help_icon.png" />
    </icons>

    <scene>
      <Scene width="700" height="600">
        <stylesheets>
          <URL value="@HelpWindow.css" />
        </stylesheets>

        <VBox spacing="10" styleClass="help-container">
          <padding>
            <Insets top="15" right="15" bottom="15" left="15"/>
          </padding>

          <Button text="Open User Guide" onAction="#handleOpenUserGuide"/>

          <TextArea fx:id="helpMessage"
                    editable="false"
                    wrapText="true"
                    VBox.vgrow="ALWAYS"
                    styleClass="help-text-area"/>
        </VBox>
      </Scene>
    </scene>
  </fx:root>
